# Normalize line endings to LF on checkin
* text=auto eol=lf

# Source
*.ts   text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary

# Generated artifacts — keep out of language stats and collapse in diffs
dist/** linguist-generated=true
package-lock.json -diff linguist-generated=true
